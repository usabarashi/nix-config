{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "autoshare": false,
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "read": "allow",
    "webfetch": "ask"
  },
  "mcp": {
    "voicevox": {
      "type": "local",
      "command": ["voicevox-mcp-server"],
      "timeout": 120000
    },
    "serena": {
      "type": "local",
      "command": [
        "serena",
        "start-mcp-server",
        "--context",
        "oaicompat-agent",
        "--project-from-cwd",
        "--enable-web-dashboard",
        "False",
        "--enable-gui-log-window",
        "False"
      ],
      "environment": {
        "SERENA_HOME": ".serena"
      }
    }
  },
  "provider": {
    "ollama-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "qwen3.6-full": {
          "name": "Qwen3.6 35B MoE Q4 full-GPU (local)",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },
  "model": "ollama-local/qwen3.6-full"
}
