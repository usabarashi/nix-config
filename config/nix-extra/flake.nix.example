# Extra flake with custom inputs (not tracked in git).
# Copy to ~/.config/nix-extra/flake.nix and customize.
# Run `nix flake update` in ~/.config/nix-extra/ to generate flake.lock.
# Note: When flake.nix is present, default.nix is ignored (flake takes priority).
#
# Export homeManagerModule and/or darwinModule to be imported by the main config.
# - homeManagerModule: user-level packages and settings (home-manager)
# - darwinModule: system-level settings such as nix substituters (nix-darwin)
{
  inputs = {
    # some-tool.url = "github:owner/some-tool";
  };

  outputs =
    {
      # some-tool,
      ...
    }:
    {
      # System-level nix-darwin module (e.g. binary cache configuration)
      darwinModule = {
        nix.settings = {
          extra-substituters = [
            # "https://example.cachix.org"
          ];
          extra-trusted-public-keys = [
            # "example.cachix.org-1:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
          ];
        };
      };

      # User-level home-manager module (e.g. packages)
      homeManagerModule =
        { pkgs, ... }:
        {
          home.packages = [
            # some-tool.packages.${pkgs.system}.default
          ];
        };
    };
}
